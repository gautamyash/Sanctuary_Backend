# Copy to .env and adjust.
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*
# Leave empty to use local SQLite (dev). For Postgres:
# DATABASE_URL=postgres://user:password@localhost:5432/sanctuary
DATABASE_URL=
# Comma-separated origins allowed to call the API (Expo dev server, prod app)
CORS_ALLOWED_ORIGINS=
